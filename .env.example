# RackPilot environment configuration
# Copy to .env and fill in your values

# Server
HOST=0.0.0.0
PORT=4173
DEBUG=false
RELOAD=false

# Database
DB_PATH=./data/fieldos.db

# Auth
SESSION_SECRET=change-me-in-production
MASTER_KEY=

# AI providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LAN mode
LAN_MODE=true

# Local Agent Coordinator (server-side only; never expose token to browser code)
COORDINATOR_URL=http://127.0.0.1:4180
COORDINATOR_TOKEN=
COORDINATOR_TIMEOUT_SECONDS=5
